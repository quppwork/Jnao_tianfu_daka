# 生产环境变量 — 复制为项目根目录 .env.production 后修改
# 宝塔部署: cp .env.production.example .env.production

# ── 站点域名（用于 CORS，填最终 HTTPS 地址）──
SITE_DOMAIN=https://your-domain.com

# ── 阿里云 RDS MySQL（推荐：复用已有实例）──
# 密码含特殊字符时需 URL 编码，例如 ! → %21   @ → %40
# DATABASE_URL=mysql+pymysql://用户名:密码@rm-xxx.mysql.rds.aliyuncs.com:3306/库名

# 方案 A：在已有库里自动建本项目表（不删不改现有业务表）
DATABASE_URL=mysql+pymysql://jingnao:你的密码@rm-bp1lqyn1su17p6nr.mysql.rds.aliyuncs.com:3306/db_fz_jingnao

# 方案 B（更推荐）：同 RDS 实例下新建独立库，与业务数据隔离
# 在 DMS 执行: CREATE DATABASE jnao_daka CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# DATABASE_URL=mysql+pymysql://jingnao:你的密码@rm-bp1lqyn1su17p6nr.mysql.rds.aliyuncs.com:3306/jnao_daka

# ── 若无 RDS、改用 Docker 内置 MySQL 时填写 ──
# MYSQL_ROOT_PASSWORD=change-me-root-password
# MYSQL_USER=jnao
# MYSQL_PASSWORD=change-me-strong-password
# MYSQL_DATABASE=jnao_daka
# DATABASE_URL=mysql+pymysql://jnao:change-me-strong-password@mysql:3306/jnao_daka

# ── 豆包 AI（必填）──
DOUBAO_API_KEY=your-ark-api-key
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_CHAT_MODEL=doubao-seed-1-6-250615
DOUBAO_VISION_MODEL=doubao-seed-1-6-250615

# ── 阿里云 OSS（训练音频，按需填写）──
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=jnao-talent-ai
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_PREFIX=yinpin/

# ── 语音服务（可选）──
SPEECH_APP_ID=
SPEECH_ACCESS_TOKEN=

# ── RAG 知识库（无内网服务时保持 1）──
TIANFU_RAG_MOCK=1
TIANFU_RAG_URL=http://127.0.0.1:8010

# ── 运行模式 ──
JNAO_ENV=production
JNAO_DEV_MODE=0
JNAO_DEBUG_ROUTES=0

# ── 前端对外端口（仅本机监听，由宝塔 Nginx 反代）──
FRONTEND_HOST_PORT=5185
