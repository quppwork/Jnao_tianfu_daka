# JNAO Backend — 环境变量
# 复制此文件为 .env 并填入真实值

# DeepSeek（备用模型）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash

# 豆包（火山引擎 Ark）
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_API_KEY=your-ark-api-key
# 使用 Ark /models 返回的完整 model id，或控制台推理接入点 ep-xxxx
DOUBAO_CHAT_MODEL=doubao-seed-1-6-250615

# 火山引擎语音服务（TTS/ASR，需单独申请）
SPEECH_APP_ID=
SPEECH_ACCESS_TOKEN=

# MySQL（生产）或留空使用 SQLite 本地库
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/jnao_daka
# DATABASE_URL=sqlite:///./data/jnao_daka.db

# 本地开发：跳过内网 tianfu_rag 探测（health 不再等 3 秒）
TIANFU_RAG_MOCK=1

# 开发者 API（训练重置/模拟下一天）；生产请设为 0
JNAO_DEV_MODE=1

# 阿里云 OSS（音频目录 yinpin/，Bucket: jnao-talent-ai 华北2北京）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=jnao-talent-ai
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_PREFIX=yinpin/
OSS_SIGNED_URL=true
OSS_SIGN_EXPIRES=7200
